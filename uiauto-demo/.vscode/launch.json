{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Py Debug",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "program": "${file}",
      "justMyCode": false
    },
    {
      "name": "PyTest Debug",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "pytest",
      "args": ["uitests/cases/hello_world.py::test_hello_world", "-s"],
      "justMyCode": false
    }
  ]
}
